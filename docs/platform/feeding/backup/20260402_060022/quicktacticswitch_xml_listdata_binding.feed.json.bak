    "overall": "MEDIUM",
    "rationale": "Observed repeatedly in addon implementations, but ListData itself is not yet covered by canonical platform documentation."
  },
  "claims": [
    {
      "claim_id": "listdata_binds_listbox_to_lua_table",
      "kind": "usage_pattern",
      "confidence": "MEDIUM",
      "symbols": [
        "ListBox",
        "ListData"
      ],
      "statement": "ListData appears to bind a ListBox to a named Lua table through its table attribute.",
      "guidance": "Treat the table attribute as the backing collection for list rows, and rebuild that Lua table before refreshing or reordering the list.",
      "evidence_refs": [
        "ev_qts_xml_listdata",
        "ev_qts_lua_backing_table"
      ]
    },
    {
      "claim_id": "listcolumns_map_table_fields_to_row_children",
      "kind": "usage_pattern",
      "confidence": "MEDIUM",
      "symbols": [
        "ListData",
        "ListColumns",
        "ListColumn"
      ],
      "statement": "ListColumn entries under ListData appear to map fields from each backing-table entry onto row-template child windows.",
      "guidance": "Use windowname and variable to bind text-bearing row children from structured table entries, and keep format declarations conservative.",
      "evidence_refs": [
        "ev_qts_xml_listcolumns"
      ]
    },
    {
      "claim_id": "populationfunction_and_populatorindices_support_custom_rows",
      "kind": "usage_pattern",
      "confidence": "MEDIUM",
      "symbols": [
        "ListData",
        "ListBoxSetDisplayOrder",
        "ListBoxGetDataIndex",
        "PopulatorIndices"
      ],
      "statement": "When populationfunction is present, Lua can perform custom row population and use PopulatorIndices plus ListBox APIs to manage visible-row ordering and row-to-data mapping.",
      "guidance": "Use ListColumns for straightforward text binding, and reserve populationfunction for extra row work such as icons or row-specific state that is not expressed directly in XML.",
      "evidence_refs": [
        "ev_qts_lua_display_order",
        "ev_qts_lua_population",
        "ev_qts_lua_row_mapping"
      ]
    },
    {
      "claim_id": "populationfunction_can_be_blank_for_text_only_lists",
      "kind": "usage_pattern",
      "confidence": "MEDIUM",
      "symbols": [
        "ListData"
      ],
      "statement": "A blank populationfunction appears to be accepted when XML column binding alone is sufficient for the list.",
      "guidance": "If the list only needs ListColumns text binding, an empty populationfunction may be enough; add a Lua population function only when the row requires extra runtime setup.",
      "evidence_refs": [
        "ev_aggrometer_blank_populationfunction"
      ]
    }
  ],
